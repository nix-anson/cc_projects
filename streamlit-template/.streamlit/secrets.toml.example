# Example secrets configuration
# Copy this file to secrets.toml and fill in your actual values
# NEVER commit secrets.toml to version control!

[database]
url = "postgresql://user:password@localhost:5432/dbname"
# For SQLite: "sqlite:///./app.db"
# For MySQL: "mysql+pymysql://user:password@localhost:3306/dbname"

[api]
base_url = "https://api.example.com"
key = "your-api-key-here"

[auth]
[auth.cookie]
name = "streamlit_auth_cookie"
key = "random_signature_key_here"  # Generate with: import secrets; secrets.token_urlsafe(32)
expiry_days = 30

[auth.credentials]
[auth.credentials.usernames]
[auth.credentials.usernames.admin]
email = "admin@example.com"
name = "Admin User"
password = "$2b$12$..." # Hash with: python -c "import streamlit_authenticator as stauth; print(stauth.Hasher(['password']).generate()[0])"

[auth.credentials.usernames.user1]
email = "user1@example.com"
name = "Regular User"
password = "$2b$12$..."

[auth.roles]
admin = ["admin"]
user = ["user1"]

[auth.pre_authorized]
emails = []

# Add other secrets as needed
[other]
secret_key = "your-secret-key"
