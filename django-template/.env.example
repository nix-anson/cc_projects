# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# OR SQLite (for development)
# DATABASE_URL=sqlite:///db.sqlite3
# OR MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# Email Configuration (choose one)
# Console (development - prints to console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP (production)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=noreply@example.com

# Redis (for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# Celery (if using async tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AWS S3 (if using for media/static files)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# Security Settings (Production)
SECURE_SSL_REDIRECT=False  # Set True in production with HTTPS
SESSION_COOKIE_SECURE=False  # Set True in production with HTTPS
CSRF_COOKIE_SECURE=False  # Set True in production with HTTPS

# API Keys (if needed)
# STRIPE_PUBLIC_KEY=your-stripe-public-key
# STRIPE_SECRET_KEY=your-stripe-secret-key
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Other Settings
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# Django Admin
ADMIN_URL=admin/  # Change in production for security
