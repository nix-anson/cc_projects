# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ─── Model ────────────────────────────────────────────────────────────────────
# HuggingFace model ID or local path under models/base/
BASE_MODEL_ID=microsoft/phi-2
# Path to a LoRA adapter directory (leave empty to skip loading an adapter)
LORA_ADAPTER_PATH=

# Generation defaults
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9
REPETITION_PENALTY=1.1

# ─── HuggingFace Hub ──────────────────────────────────────────────────────────
# Required for gated models (Llama 3, Mistral-7B-Instruct, etc.)
HF_TOKEN=

# ─── Training ─────────────────────────────────────────────────────────────────
OUTPUT_DIR=models/adapters
LOGGING_DIR=logs
