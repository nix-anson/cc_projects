# API Configuration
VITE_API_URL=http://localhost:3000/api

# App Configuration
VITE_APP_NAME=My React App
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# IMPORTANT: Never put secrets in environment variables prefixed with VITE_
# They will be exposed to the client! Keep secrets server-side only.
