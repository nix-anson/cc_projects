{
  "model": "sonnet",
  "outputStyle": "markdown",
  "environmentVariables": {
    "FLASK_APP": "wsgi.py",
    "FLASK_ENV": "development",
    "PYTHONPATH": "."
  },
  "hooks": {
    "PostToolUse": {
      "command": "black {filePath}",
      "patterns": ["*.py"],
      "description": "Auto-format Python files with Black after editing"
    }
  },
  "permissions": {
    "deny": {
      "read": [".env", "*.key", "*.pem", "Secrets.*", "*.secret"],
      "write": [".env", "*.key", "*.pem", "Secrets.*", "*.secret"]
    }
  }
}
