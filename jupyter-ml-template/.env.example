# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Python Environment
PYTHONPATH=./src

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=default

# Weights & Biases Configuration (optional)
# WANDB_API_KEY=your_wandb_api_key_here
# WANDB_PROJECT=jupyter-ml-project
# WANDB_ENTITY=your_username_or_team

# Data Paths
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_INTERIM_PATH=./data/interim

# Model Paths
MODEL_SAVE_PATH=./models/saved_models
MODEL_CHECKPOINT_PATH=./models/checkpoints

# Jupyter Configuration
JUPYTER_PORT=8888
JUPYTER_TOKEN=  # Leave empty for no token (development only!)

# API Keys (if needed for external data sources)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# GOOGLE_API_KEY=your_google_api_key

# Database Configuration (if needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Random Seeds (for reproducibility)
RANDOM_SEED=42
